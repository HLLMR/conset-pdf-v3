{
  "name": "conset-pdf-monorepo",
  "version": "1.0.0",
  "description": "Monorepo for conset-pdf: core library and CLI",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:core && npm run build:cli",
    "build:core": "npm run build --workspace=@conset-pdf/core",
    "build:cli": "npm run build --workspace=@conset-pdf/cli",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:smoke": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/smoke",
    "verify": "npm run build && npm run test:smoke && npm run verify:invariants",
    "verify:invariants": "node scripts/verify-invariants.js",
    "clean": "npm run clean --workspaces --if-present"
  },
  "keywords": [
    "pdf",
    "construction",
    "drawings",
    "specs",
    "addenda",
    "merge"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.19.29",
    "@types/pdf-parse": "^1.1.5",
    "glob": "^13.0.0",
    "jest": "^29.7.0",
    "playwright": "^1.57.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
