{
  "name": "@conset-pdf/core",
  "version": "1.0.0",
  "description": "Core library for merging addenda and managing construction document sets",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-sidecars.mjs",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "pdf",
    "construction",
    "drawings",
    "specs",
    "addenda",
    "merge"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.530",
    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.29",
    "typescript": "^5.3.3"
  }
}
