{
  "name": "Standard Title Block Layout",
  "version": "1.0.0",
  "description": "Example layout profile for standard 24\"×36\" landscape drawings with bottom-right title block",
  "source": "user-defined",
  "page": {
    "orientation": "landscape",
    "roiSpace": "visual"
  },
  "sheetId": {
    "rois": [
      {
        "x": 0.75,
        "y": 0.0,
        "width": 0.20,
        "height": 0.15
      }
    ],
    "regex": "\\b([A-Z]{1,3}\\s*\\d{0,2}\\s*[-._ ]\\s*\\d{1,3}(?:\\.\\d+)?[A-Z]{0,3})\\b",
    "anchorKeywords": ["SHEET", "SHT", "DWG NO", "DWG", "DRAWING NO", "DRAWING", "SHEET NO", "SHEET NO.", "SHEETNUMBER"]
  },
  "sheetTitle": {
    "rois": [
      {
        "x": 0.50,
        "y": 0.0,
        "width": 0.30,
        "height": 0.15
      }
    ],
    "maxLength": 100
  },
  "validation": {
    "allowedPrefixes": ["M", "E", "P", "A", "S", "C", "G"]
  }
}
